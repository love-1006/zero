    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "RED Method: Rate - 초당 요청 수.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "id": 4,
      "targets": [
        {
          "expr": "rate(health_check_requests_total[5m])",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ],
      "title": "Rate - /health Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "RED Method: Duration - 요청의 95번째 백분위 응답시간. OTel FastAPIInstrumentor 계측 히스토그램 기반.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "id": 109,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket{job=\"ci-sandbox\"}[5m])))",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ],
      "title": "Duration - p95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "RED Method: Errors - 5xx 응답 비율. 5분간 5% 초과 시 Critical 알림(High App Error Rate 규칙).",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "(sum(rate(http_server_duration_milliseconds_count{job=\"ci-sandbox\", http_status_code=~\"5..\"}[5m])) OR on() vector(0)) / sum(rate(http_server_duration_milliseconds_count{job=\"ci-sandbox\"}[5m])) * 100",
          "instant": true,
          "legendFormat": "5xx error rate",
          "refId": "A"
        }
      ],
      "title": "Errors - ci_sandbox App 5xx Error Rate (%)",
      "type": "stat"
