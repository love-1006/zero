{
  "apiVersion": 1,
  "policies": [
    {
      "orgId": 1,
      "receiver": "slack-alerts",
      "group_by": ["grafana_folder", "alertname"],
      "routes": [
        {
          "receiver": "slack-critical",
          "object_matchers": [["severity", "=", "critical"]]
        }
      ]
    }
  ]
}
