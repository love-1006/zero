## Ansible managed
[global]
repo1-type=s3
repo1-s3-endpoint=pgbackrest-minio-tls
repo1-storage-port=9443
repo1-s3-bucket=pgbackrest-repo
repo1-s3-region=us-east-1
repo1-s3-key=<REPLACE_ME>
repo1-s3-key-secret=<REPLACE_ME>
repo1-s3-uri-style=path
repo1-storage-verify-tls=n
repo1-path=/pgbackrest/pgvector
repo1-retention-full=2
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass=<REPLACE_ME>

archive-async=y
spool-path=/var/spool/pgbackrest
process-max=2
start-fast=y
archive-check=y
log-level-console=info
log-level-file=detail
log-path=/var/log/pgbackrest

[pgvector]
pg1-path=/var/lib/postgresql/data
pg1-database=zero
pg1-user=yesman
