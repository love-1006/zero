NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:8000/social-access/naver/callback

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/social-access/kakao/callback

# Not functional yet — client id/secret placeholders only, see app/services/oauth/google.py.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/social-access/google/callback

# Not functional yet — Apple additionally needs a Team ID/Key ID/private key to
# sign the token-exchange client assertion, see app/services/oauth/apple.py.
APPLE_CLIENT_ID=
APPLE_REDIRECT_URI=http://localhost:8000/social-access/apple/callback

JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=180

# Cloudflare Turnstile secret key (server-side verification for /administrator-login).
# Get it from the Cloudflare dashboard: Turnstile > your widget > Secret Key.
TURNSTILE_SECRET_KEY=

# Shared secret required by POST /administrator-signup to create a new admin account.
# Keep this out of any public client — only whoever provisions admins should know it.
# Empty = signup endpoint is disabled entirely.
ADMIN_SIGNUP_SECRET=

POSTGRES_HOST=211.46.52.151
POSTGRES_PORT=15432
POSTGRES_DB=test_db
POSTGRES_USER=여기에 입력
POSTGRES_PASSWORD=여기에 입력

# 세션/OAuth state/rate-limit 저장용 (app/services/session_store.py,
# state_store.py, rate_limiter.py)
REDIS_HOST=192.168.0.54
REDIS_PORT=6379