# product-service .env에 있는 값을 그대로 복사해서 쓰면 됩니다 (읽기 전용 조회만 함).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=test_db
POSTGRES_USER=
POSTGRES_PASSWORD=

# Anthropic 다이렉트 API (product-service와 동일한 값 재사용 가능)
ANTHROPIC_API_KEY=

# AWS Bedrock — 액세스키 방식 또는 AWS_PROFILE 둘 중 하나만 있으면 됨
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# AWS_PROFILE=

OPENAI_API_KEY=

GEMINI_API_KEY=

# 상품 몇 개를 뽑아 테스트할지
EVAL_SAMPLE_SIZE=5
