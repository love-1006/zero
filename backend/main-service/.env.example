# Must be identical to login-service's JWT_SECRET — main-service only
# verifies tokens issued by login-service, it never issues its own.
JWT_SECRET=dev-secret-change-me
# Must match login-service's JWT_EXPIRE_MINUTES (sliding-session refresh).
JWT_EXPIRE_MINUTES=180

FRONTEND_URL=http://localhost:3000

# Same Postgres instance as login-service — the `service` schema is
# provisioned/migrated by the data team, this app never runs DDL against it.
POSTGRES_HOST=211.46.52.151
POSTGRES_PORT=15432
POSTGRES_DB=test_db
POSTGRES_USER=여기에 입력
POSTGRES_PASSWORD=여기에 입력
