# Same Postgres instance as the other services. This service is read-only —
# recipes/recipe_ingredients/recipe_ingredient_products/raw_ingredient_nutrients
# are all populated by the data team's recipe pipeline.
POSTGRES_HOST=<db-host>
POSTGRES_PORT=5432
POSTGRES_DB=test_db
POSTGRES_USER=여기에 입력
POSTGRES_PASSWORD=여기에 입력

FRONTEND_URL=http://localhost:3000
