# Must be identical to login-service's JWT_SECRET — community-service only
# verifies tokens issued by login-service, it never issues its own.
JWT_SECRET=dev-secret-change-me

FRONTEND_URL=http://localhost:3000

# Same Postgres instance as login-service/main-service. This service owns and
# self-migrates its own `community` schema (see app/main.py) — unlike the
# `service` schema, which is provisioned by the data team.
POSTGRES_HOST=211.46.52.151
POSTGRES_PORT=15432
POSTGRES_DB=test_db
POSTGRES_USER=여기에 입력
POSTGRES_PASSWORD=여기에 입력
