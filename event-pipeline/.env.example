# Copy only to an out-of-repository chmod 600 secret file, never commit real values.
PIPELINE_DB_PASSWORD=replace-with-dedicated-password
MINIO_ACCESS_KEY=replace-with-existing-diet-photos-service-account
MINIO_SECRET_KEY=replace-with-existing-diet-photos-service-account-secret

# Active image-analysis provider. Use Gemini today; FoodLens needs vendor REST details.
VISION_PROVIDER=gemini
PROCESSOR_VERSION=gemini-v1
GEMINI_API_KEY=replace-with-rotated-gemini-key
GEMINI_MODEL=gemini-flash-latest
# Unbounded thinking made the model emit truncated JSON on crowded plates.
GEMINI_THINKING_BUDGET=512
GEMINI_MAX_OUTPUT_TOKENS=4096
VISION_TIMEOUT_SECONDS=30
VISION_MAX_IMAGE_BYTES=10485760
VISION_CONFIDENCE_THRESHOLD=0.75
# Transient provider failures (HTTP 429/5xx, unavailable) are retried with
# exponential backoff: 2s, 4s. Permanent failures fail on the first attempt.
VISION_MAX_ATTEMPTS=3
VISION_RETRY_BACKOFF_SECONDS=2

# Enable only with: docker compose --profile analytics ... up -d activity-consumer
# Mongo _id is event_id; each event's user_id is PostgreSQL public.users.id.
MONGODB_URI=mongodb://dedicated-analytics-user:replace@mongodb:27017/?authSource=admin
ACTIVITY_MONGODB_DATABASE=dangdang_analytics
ACTIVITY_MONGODB_COLLECTION=user_activity_events

# Do not guess these. Populate only from FoodLens REST API documentation/support.
# VISION_PROVIDER=foodlens
# FOODLENS_API_URL=https://vendor-supplied-recognition-endpoint
# FOODLENS_TOKEN=vendor-supplied-app-token
# FOODLENS_TOKEN_HEADER=Authorization
# FOODLENS_TOKEN_PREFIX=Bearer 
# FOODLENS_IMAGE_FIELD=image

# Connection pooling replaces a fresh TCP connect per job once workers scale out.
DB_POOL_MIN_SIZE=1
API_DB_POOL_MAX_SIZE=20
WORKER_DB_POOL_MAX_SIZE=4
# Published outbox rows are swept after this many days. Must stay well above
# Kafka retention so the duplicate-publish guard outlives any redelivery.
OUTBOX_RETENTION_DAYS=30
OUTBOX_CLEANUP_INTERVAL_SECONDS=3600

# zero DB (zero-pg-vector) outbox publisher — publishes service.event_outbox
# rows to Kafka. The table is owned by the data/infra team; backend services
# only INSERT into it. Use the backend app account, not a superuser.
ZERO_DATABASE_URL=postgresql://replace-user:replace-password@zero-pg-vector:5432/zero
ZERO_OUTBOX_POLL_SECONDS=0.5
ZERO_OUTBOX_MAX_PUBLISH_ATTEMPTS=50
