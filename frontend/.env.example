# Browser requests always use /b. When a gateway is available, set only this URL.
# Same-server Compose: http://b-gateway:8080
# LAN test example: http://192.168.0.13:8080
# The proxy automatically appends /b, so both http://host and http://host/b are accepted.
BACKEND_GATEWAY_URL=

# Public address that browsers and backend workers can both reach.
# Used when a temporary uploaded image URL is handed to the diet service.
PUBLIC_APP_URL=http://localhost:3001

# Local development fallback when there is no gateway.
LOGIN_SERVICE_URL=http://127.0.0.1:8000
ADMIN_SERVICE_URL=http://127.0.0.1:8008
MAIN_SERVICE_URL=http://127.0.0.1:8010
COMMUNITY_SERVICE_URL=http://127.0.0.1:8012
RECIPE_SERVICE_URL=http://127.0.0.1:8014
PRODUCT_SERVICE_URL=http://127.0.0.1:8016
INGREDIENTS_SERVICE_URL=http://127.0.0.1:8018
DIET_SERVICE_URL=http://127.0.0.1:8020
